dist/

# generated types
.astro/
demo
plans

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
*.err.log

# environment variables
.env
.env.production

# content repository (independent mode)
/content/
*.backup

# Large zip files
*.zip

