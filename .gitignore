.DS_Store

.vercel

package-lock.json
bun.lockb
yarn.lock
temp-css.txt

# ide
.idea
*.iml
.claude

cache/
fuwari/
src/data/myself.ts
src/pages/myself.astro

# Bangumi generated data
src/data/bangumi-data.json

# Bilibili generated data
src/data/bilibili-data.json

# Lighthouse CI
.lighthouseci/

# SQLite database
data/site.db
data/*.db-shm
data/*.db-wal

# Rebuild runtime state (written by /api/admin/rebuild)
data/rebuild.state.json
data/rebuild.log

# Upload files
public/uploads/

# Admin-managed post content (source of truth is data/site.db; .md files are
# regenerated from the DB by scripts/sync-db-posts.mjs during prebuild).
# Tracking them in git makes `git pull` resurrect posts the admin deleted.
src/content/posts/**/*.md
src/content/posts/**/*.mdx

# Admin-managed runtime content (written by the admin panel on the server).
# Tracking these in git would let `git pull` overwrite live edits on deploy.
# 关于我 / About-me page body
src/content/spec/about.md
# 关于本站 / About-this-site page body
src/content/spec/about-site.md
# 相册 / Album photos uploaded via admin. Each album is its own subdirectory;
# README.md stays tracked because it's a file (not matched by `*/`);
# HiddenExample stays tracked as a repo example template.
public/images/albums/*/
!public/images/albums/HiddenExample/
