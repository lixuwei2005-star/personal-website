---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import DataTable from "../../components/admin/DataTable.svelte";
import { getAllFriends } from "../../lib/repositories/friends";

const friends = getAllFriends();
---

<AdminLayout title="Friends">
	<DataTable
		client:load
		apiBase="/api/admin/friends"
		items={friends}
		columns={[
			{ key: "title", label: "Name" },
			{ key: "imgurl", label: "Avatar", type: "image" },
			{ key: "desc", label: "Description" },
			{ key: "siteurl", label: "URL" },
			{ key: "tags", label: "Tags", type: "tags" },
		]}
		editFields={[
			{ key: "title", label: "Name" },
			{ key: "imgurl", label: "Avatar URL", type: "image" },
			{ key: "desc", label: "Description" },
			{ key: "siteurl", label: "Site URL" },
			{ key: "tags", label: "Tags", type: "tags" },
		]}
	/>
</AdminLayout>
